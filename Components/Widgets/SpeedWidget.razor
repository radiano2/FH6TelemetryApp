<div class="gauge-wrap">
    <svg viewBox="0 0 200 200" width="100%" style="max-width:190px;max-height:190px;overflow:visible">
        <defs>
            <linearGradient id="gSpeed" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#00c9a7"/>
                <stop offset="75%" stop-color="#00e5cc"/>
                <stop offset="100%" stop-color="#ff4757"/>
            </linearGradient>
        </defs>
        <circle cx="100" cy="100" r="78" fill="none" stroke="#edf2f7" stroke-width="13"
                stroke-dasharray="409 10000" stroke-dashoffset="-107" stroke-linecap="round"/>
        <circle cx="100" cy="100" r="78" fill="none" stroke="url(#gSpeed)" stroke-width="13"
                stroke-dasharray="@_arc 10000" stroke-dashoffset="-107" stroke-linecap="round"
                style="transition:stroke-dasharray 0.05s"/>
        <line x1="100" y1="34" x2="100" y2="72"
              stroke="var(--mint)" stroke-width="3" stroke-linecap="round"
              transform="rotate(@_needleDeg 100 100)"/>
        <circle cx="100" cy="100" r="7" fill="var(--mint)"/>
        <circle cx="100" cy="100" r="3.5" fill="white"/>
        <text x="100" y="118" text-anchor="middle" font-family="Segoe UI,system-ui"
              font-size="38" font-weight="800" fill="#1a2332">@_display</text>
        <text x="100" y="137" text-anchor="middle" font-family="Segoe UI,system-ui"
              font-size="12" fill="#6b7f96">@_unit</text>
        <text x="28"  y="160" text-anchor="middle" font-family="Segoe UI,system-ui" font-size="9" fill="#aaa">0</text>
        <text x="172" y="160" text-anchor="middle" font-family="Segoe UI,system-ui" font-size="9" fill="#aaa">@_maxLabel</text>
    </svg>
</div>

@code {
    [Parameter] public TelemetryPacket? Packet { get; set; }
    [Parameter] public bool UseMph { get; set; }

    private static readonly float s_arcMax = 2f * MathF.PI * 78f * (270f / 360f);

    private string _arc       = "0";
    private string _needleDeg = "-135";
    private string _display   = "0";
    private string _unit      = "km/h";
    private string _maxLabel  = "300";

    protected override void OnParametersSet()
    {
        var ms = Packet?.Speed ?? 0f;
        float speed, max;
        if (UseMph) { speed = TelemetryUnits.SpeedMph(ms); max = 186f; _unit = "mph"; _maxLabel = "186"; }
        else        { speed = TelemetryUnits.SpeedKph(ms); max = 300f; _unit = "km/h"; _maxLabel = "300"; }

        var ratio  = Math.Clamp(speed / max, 0f, 1f);
        _arc       = I(ratio * s_arcMax);
        _needleDeg = I(-135f + ratio * 270f);
        _display   = ((int)speed).ToString();
    }

    private static string I(float v) =>
        v.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
}
